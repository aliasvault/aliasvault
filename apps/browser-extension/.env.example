# Midnight network: mainnet | preprod | preview | qanet | undeployed
VITE_MIDNIGHT_NETWORK=undeployed

# Per-service URL overrides (all optional — each defaults to the network config value).
# Useful for QA, custom devnet, or pointing the extension at a locally-tunnelled
# service without editing networkConfig.ts. 6.5b review L2.
# VITE_INDEXER_URL=http://localhost:8088/api/v4/graphql
# VITE_WS_INDEXER_URL=ws://localhost:8088/api/v4/graphql/ws
# VITE_NODE_URL=http://localhost:9944
# VITE_PROOF_SERVER_URL=http://localhost:6300

# Pinata IPFS credentials (required for vault save/load)
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=
