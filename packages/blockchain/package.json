{
  "name": "@aliasvault/blockchain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "cli",
    "contract"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "tui-local": "cd cli && node --experimental-specifier-resolution=node --loader ts-node/esm src/tui_local.ts",
    "vault-registry": "cd cli && node --experimental-specifier-resolution=node --loader ts-node/esm src/tui_vault_registry.ts",
    "deploy-local": "cd cli && node --experimental-specifier-resolution=node --loader ts-node/esm src/deploy-vault-registry.ts --network=local",
    "deploy-preview": "cd cli && node --experimental-specifier-resolution=node --loader ts-node/esm src/deploy-vault-registry.ts --network=preview",
    "deploy-preprod": "cd cli && node --experimental-specifier-resolution=node --loader ts-node/esm src/deploy-vault-registry.ts --network=preprod",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "testcontainers": "^11.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.4.0",
    "@midnight-ntwrk/compact-runtime": "0.14.0",
    "@midnight-ntwrk/ledger": "^4.0.0",
    "@midnight-ntwrk/ledger-v7": "7.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "3.1.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-network-id": "3.1.0",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-types": "3.1.0",
    "@midnight-ntwrk/midnight-js-utils": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "1.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "1.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "1.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "1.0.0",
    "@rollup/rollup-linux-x64-gnu": "^4.58.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.2",
    "ws": "^8.19.0"
  }
}
