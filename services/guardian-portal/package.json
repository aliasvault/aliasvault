{
  "name": "@aliasvault/guardian-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "copy-zk-assets": "mkdir -p public/keys public/zkir && cp -r ../../packages/blockchain/contract/src/managed/guardian-recovery/keys/* public/keys/ && cp -r ../../packages/blockchain/contract/src/managed/guardian-recovery/zkir/* public/zkir/",
    "build": "tsc -b && npm run copy-zk-assets && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aliasvault/vault-sync": "workspace:*",
    "@aliasvault/contract": "workspace:*",
    "@midnight-ntwrk/compact-js": "2.4.0",
    "@midnight-ntwrk/midnight-js-contracts": "3.0.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.0.0",
    "@midnight-ntwrk/compact-runtime": "0.14.0",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "3.0.0",
    "@midnight-ntwrk/ledger-v7": "7.0.0",
    "@midnight-ntwrk/midnight-js-types": "3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^3.2.0"
  }
}
